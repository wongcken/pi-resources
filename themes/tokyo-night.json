{
	"$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
	"name": "tokyo-night",
	"description": "Tokyo Night theme for Pi - optimized for Tokyo Night terminal colors",
	"vars": {
		"bg": "#1a1b26",
		"bg-alt": "#24283b",
		"bg-highlight": "#2f3349",
		"fg": "#a9b1d6",
		"fg-bright": "#c0caf5",
		"fg-dark": "#565f89",
		"blue": "#7aa2f7",
